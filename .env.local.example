# Copy to .env.local (never commit .env.local).

# Convex deployment URL from `npx convex dev` or the Convex dashboard.
NEXT_PUBLIC_CONVEX_URL=https://YOUR_DEPLOYMENT.convex.cloud

# Groq — required for Mains evaluation and AI chat (Next.js API routes).
# Create a key at https://console.groq.com/keys — must start with gsk_
GROQ_API_KEY=gsk_REPLACE_ME

# Optional override for Groq chat/completions (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# --- Optional third-party keys (only if you wire them in) ---
# EXA_API_KEY=
# APIFY_TOKEN=

# --- Convex dashboard → Settings → Environment variables (not Next.js) ---
# PRELIMS_INGEST_SECRET=<long random string>
# Apify (or any ETL) POSTs JSON { "items": [...] } to
# https://<deployment>.convex.site/ingest/prelims
# with header x-prelims-ingest-secret: <same secret>.
# Run once locally after schema push: npm run convex:seed-prelims

# --- Convex Auth (REQUIRED on Convex deployment or sign-in fails: Missing JWT_PRIVATE_KEY) ---
# These are NOT read from .env.local by Convex — run `npx convex env set` or set in the dashboard.
#
# Generate PEM + JWKS files, then push to Convex (PEM must keep newlines — no spaces instead of \n):
#   npm run generate-jwt-keys
#   npx convex env set JWT_PRIVATE_KEY --from-file secrets/convex-jwt-private.pem
#   npx convex env set JWKS --from-file secrets/convex-jwks.json
# Do NOT use "$(cat ...pem)" — PEM lines start with "-----" and break the CLI as "flags".
# If "pkcs8 must be PKCS#8 formatted string", regenerate keys or use the dashboard paste.
#   npx convex env set SITE_URL http://localhost:3000
#   npx convex env set CONVEX_SITE_URL https://YOUR_DEPLOYMENT.convex.cloud
# Google OAuth (optional): npx convex env set AUTH_GOOGLE_ID ... && npx convex env set AUTH_GOOGLE_SECRET ...
# Callback URL in Google Cloud: https://YOUR_DEPLOYMENT.convex.site/api/auth/callback/google
